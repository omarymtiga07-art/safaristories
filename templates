<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Safari Stories - Explore Morogoro</title>
    <style>
        /* Basic Reset & Typography */
        * { margin: 0; padding: 0; box-sizing: border-box; font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; }
        body { background-color: #FAF9F6; color: #212529; line-height: 1.6; }

        /* Navigation Bar */
        header { background-color: #2E5A44; padding: 20px; display: flex; justify-content: space-between; align-items: center; color: white; }
        header .logo { font-size: 24px; font-weight: bold; letter-spacing: 1px; }
        header nav a { color: white; text-decoration: none; margin-left: 20px; font-weight: 500; }
        header nav a:hover { color: #D4A373; }

        /* Hero / Welcome Banner */
        .hero { 
            background: linear-gradient(rgba(0, 0, 0, 0.5), rgba(0, 0, 0, 0.4)), url('https://images.unsplash.com/photo-1516426122078-c23e76319801?q=80&w=1200') no-repeat center center/cover;
            height: 60vh; display: flex; flex-direction: column; justify-content: center; align-items: center; color: white; text-align: center; padding: 20px;
        }
        .hero h1 { font-size: 48px; margin-bottom: 10px; text-shadow: 2px 2px 4px rgba(0,0,0,0.6); }
        .hero p { font-size: 20px; margin-bottom: 20px; max-width: 600px; text-shadow: 1px 1px 3px rgba(0,0,0,0.6); }
        .btn { background-color: #D4A373; color: white; padding: 12px 30px; text-decoration: none; font-weight: bold; border-radius: 5px; transition: 0.3s; }
        .btn:hover { background-color: #b88553; }

        /* Attractions Section */
        .container { max-width: 1200px; margin: 50px auto; padding: 0 20px; }
        .section-title { text-align: center; font-size: 32px; color: #2E5A44; margin-bottom: 40px; position: relative; }
        
        .grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 30px; }
        .card { background: white; border-radius: 10px; overflow: hidden; box-shadow: 0 4px 15px rgba(0,0,0,0.05); transition: 0.3s; }
        .card:hover { transform: translateY(-5px); }
        .card img { width: 100%; height: 220px; object-fit: cover; }
        .card-content { padding: 20px; }
        .card-content h3 { color: #2E5A44; margin-bottom: 10px; }
        
        /* Footer */
        footer { background-color: #212529; color: #a0a0a0; text-align: center; padding: 30px; margin-top: 50px; font-size: 14px; }
    </style>
</head>
<body>

    <!-- Navigation -->
    <header>
        <div class="logo">Safari Stories</div>
        <nav>
            <a href="#">Home</a>
            <a href="#">Destinations</a>
            <a href="#">Stories</a>
            <a href="#">Contact</a>
        </nav>
    </header>

    <!-- Hero Banner -->
    <section class="hero">
        <h1>Discover Morogoro</h1>
        <p>From the mist-covered Uluguru peaks to the endless wildlife paths of Mikumi. Read the stories behind the journey.</p>
        <a href="#" class="btn">Explore Stories</a>
    </section>

    <!-- Attractions Grid -->
    <main class="container">
        <h2 class="section-title">Top Attractions in Morogoro</h2>
        
        <div class="grid">
            <!-- Card 1: Mikumi -->
            <div class="card">
                <img src="https://images.unsplash.com/photo-1547471080-7cc2caa01a7e?q=80&w=600" alt="Mikumi National Park">
                <div class="card-content">
                    <h3>Mikumi National Park</h3>
                    <p>Often compared to the Serengeti, Mikumi offers accessible and stunning wildlife viewing right off the highway. Spot lions, zebras, and elephants.</p>
                </div>
            </div>

            <!-- Card 2: Uluguru Mountains -->
            <div class="card">
                <img src="https://images.unsplash.com/photo-1464822759023-fed622ff2c3b?q=80&w=600" alt="Uluguru Mountains">
                <div class="card-content">
                    <h3>Uluguru Mountains</h3>
                    <p>Perfect for hikers and culture seekers. Experience breathtaking waterfalls, morning mountain mists, and local traditional Waluguru culture.</p>
                </div>
            </div>

            <!-- Card 3: Udzungwa Mountains -->
            <div class="card">
                <img src="https://images.unsplash.com/photo-1441974231531-c6227db76b6e?q=80&w=600" alt="Udzungwa Mountains">
                <div class="card-content">
                    <h3>Udzungwa National Park</h3>
                    <p>An absolute treasure trove of biodiversity. Hike to the famous Sanje Waterfalls and catch a glimpse of rare, unique monkey species.</p>
                </div>
            </div>
        </div>
    </main>

    <!-- Footer -->
    <footer>
        <p>&copy; 2026 Safari Stories. Made with passion for Tanzanian Tourism.</p>
    </footer>

</body>
</html>
